    "test:judge": "node tests/judge.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "js-yaml": "^4.2.0",
    "whois": "^2.14.1",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "playwright": "^1.49.0"
  }

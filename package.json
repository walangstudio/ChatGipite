{
  "name": "chatgipite",
  "version": "0.6.0",
  "description": "ChatGipite by Lugitech: business idea generation, validation, and execution planning. MCP stdio server compatible with Claude, Cursor, Zed, Windsurf, Continue.dev, and any MCP-capable client.",
  "main": "server.js",
  "type": "module",
  "bin": {
    "chatgipite": "./server.js"
  },
  "scripts": {
